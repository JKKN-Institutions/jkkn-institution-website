# Environment variable template for jkkn-institution-website
# Copy to .env.local and fill in values. Never commit .env.local.

# ── Institution Identity (per-Vercel-project) ──
NEXT_PUBLIC_INSTITUTION_ID=
NEXT_PUBLIC_INSTITUTION_NAME=
NEXT_PUBLIC_SITE_URL=

# ── Supabase (institution-specific project) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Feature flags ──
NEXT_PUBLIC_FEATURES=

# ── Vercel Cron auth (existing) ──
CRON_SECRET=

# ── MyJKKN Staff API (Engineering only — set on the Engineering Vercel project) ──
JKKN_API_BASE_URL=https://www.jkkn.ai/api
JKKN_API_KEY=
JKKN_ENGINEERING_INSTITUTION_ID=
FACULTY_SYNC_SECRET=
